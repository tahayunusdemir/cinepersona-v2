# Public site URL (used for OG images, absolute links, redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project URL + Publishable key (from Connect / Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# TMDB — API Read Access Token (v4 Bearer; works for v3 too).
# Server-only (NOT NEXT_PUBLIC_). Used by the TMDB → Supabase sync job
# that mirrors movies/genres/credits into Supabase. The /films page itself
# reads from Supabase and does not need this token.
# Get one at: https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=

# Supabase — service role key (server-only secret).
# Required by scripts/seed-tmdb.mjs to bypass RLS while writing to the
# TMDB mirror tables. Never expose to the client. Rotate if leaked.
# Dashboard → Project Settings → API → "service_role" secret.
SUPABASE_SERVICE_ROLE_KEY=
